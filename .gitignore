# ============================================================
# Wall-Verse — .gitignore
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ─────────────────────────────────────
/.next/
/out/
/build

# ── SECRETS — never commit these ─────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# ── OS / editor junk ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
*.key
*.p12
*.pfx

# ── Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Testing ───────────────────────────────────────────────────
/coverage

# ── Vercel ────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Misc ──────────────────────────────────────────────────────
.turbo
.cache
